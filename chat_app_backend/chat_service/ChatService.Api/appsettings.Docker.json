{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.SignalR": "Debug",
      "Microsoft.AspNetCore.Authentication.JwtBearer": "Debug"
    }
  },
  "AllowedHosts": "*",
  "AWS": {
    "AccessKey": "YOUR_ACCESS_KEY_ID",
    "SecretKey": "YOUR_SECRET_ACCESS_KEY",
    "ServiceURL": "http://dynamodb-local:8000",
    "Region": "us-east-1"
  },
  "Jwt": {
    "Key": "your-very-secure-secret-key-must-be-long-enough"
  },
  "ConnectionStrings": {
    "Redis": "redis-local:6379,abortConnect=false"
  },
  "RabbitMQ": {
    "HostName": "rabbitmq-local",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "ExchangeName": "chat_exchange"
  },
  "Spring": {
    "Application": {
      "Name": "chat-service-api"
    }
  },
  "Eureka": {
    "Client": {
      "ServiceUrl": "http://eureka-server:8761/eureka/",
      "ShouldRegisterWithEureka": true,
      "ShouldFetchRegistry": false
    },
    "Instance": {
      "PreferIpAddress": true,
      "Port": 8081,
      "AppName": "chat-service-api",
      "MetadataMap": {
        "Region": "DEFAULT" 
      }
    }
  }
}
